[Unit]
Description=Miner status service for simple-miner-dash
Documentation=https://github.com/yourrepo/simple-miner-dash
After=network.target

[Service]
Type=simple
User=miner-svc
Group=miner-svc

ExecStart=/usr/bin/python3 /opt/miner-service/server.py
Restart=on-failure
RestartSec=5

# Harden the process: read-only access to ckpool user logs and pool status files
# When adding a new pool to POOLS in server.py, add its directories here too.
ReadOnlyPaths=/var/log/ckpool-solo/users /var/log/ckpool-solo-lhr/users /var/log/ckpool-solo/pool /var/log/ckpool-solo-lhr/pool
# Prevent writing anywhere else
ReadWritePaths=
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
CapabilityBoundingSet=

# Limit network to loopback (service should never reach the internet directly)
RestrictAddressFamilies=AF_INET AF_UNIX
IPAddressDeny=any
IPAddressAllow=127.0.0.1/8

[Install]
WantedBy=multi-user.target
